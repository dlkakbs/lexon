# Telegram
TELEGRAM_BOT_TOKEN=                      # @BotFather'dan al
TELEGRAM_OWNER_IDS=                      # Telegram user ID'n (virgülle ayır)

# AI — Intent Parsing
# Provider: "openrouter" | "anthropic" | "openai"
AI_PROVIDER=openrouter
AI_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_API_KEY=                      # openrouter.ai

# OpenAI (yalnızca Whisper ses transkripsiyonu için)
OPENAI_API_KEY=                          # platform.openai.com

# Base Mainnet RPC
BASE_RPC_URL=https://mainnet.base.org

# OWS Wallet
OWS_WALLET_NAME=lexon-wallet
OWS_API_KEY=                             # npx tsx setup.ts ile oluştur (ows key create)
                                         # Boş bırakırsan owner mode — policy bypass edilir

# x402 Commerce Layer
X402_EVM_PRIVATE_KEY=                    # x402 ödemeleri için ayrı bir EVM private key
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
X402_DEFAULT_PRICE=0.01                  # USD cinsinden
X402_REMOTE_RESEARCH_URL=               # Opsiyonel: uzak research endpoint'i

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Zerion — Portfolio & DeFi verisi (dashboard.zerion.io)
ZERION_API_KEY=

# Allium — Base cüzdan analizi (allium.so)
ALLIUM_API_KEY=

# Honcho — Kişiselleştirilmiş hafıza (opsiyonel)
HONCHO_API_KEY=

# OWS Spend Limits
MAX_SEND_USDC=100
MAX_DAILY_USDC=100
MAX_SWAP_USD=100
MAX_SWAP_USDC=100
OWS_MAX_ETH_PER_TX=0.05
OWS_MAX_TX_PER_DAY=20
OWS_COOLDOWN_SECONDS=30
OWS_MAX_PER_ADDRESS_DAILY=50
OWS_CONFIRM_ABOVE_USDC=25

# OWS Policy
OWS_POLICY_EXPIRY=2027-01-01T00:00:00Z
OWS_ALLOWED_CHAINS=eip155:8453,eip155:1,eip155:137,eip155:42161,eip155:10,eip155:56,eip155:43114,eip155:324,eip155:59144,eip155:534352,eip155:81457,eip155:5000,eip155:130
# OWS_ALLOWED_CONTRACTS=0x...           # Ekstra contract adresleri (virgülle ayır)
